{
  "manifest_version": 3,
  "name": "Hotel & Airbnb Price Comparator",
  "version": "0.2.0",
  "description": "Compare hotel & Airbnb prices side-by-side while browsing Booking.com, Airbnb, and Expedia.",
  "permissions": [
    "storage",
    "notifications",
    "activeTab",
    "scripting",
    "alarms",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup/index.html"
  },
  "host_permissions": [
    "*://*.booking.com/*",
    "*://*.airbnb.com/*",
    "*://*.airbnb.co.in/*",
    "*://*.expedia.com/*",
    "*://*.expedia.co.in/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.booking.com/*"
      ],
      "js": [
        "parsers/base.js",
        "content_scripts/base_detector.js",
        "parsers/booking.js",
        "content_scripts/booking_detector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.airbnb.com/*",
        "*://*.airbnb.co.in/*"
      ],
      "js": [
        "parsers/base.js",
        "content_scripts/base_detector.js",
        "parsers/airbnb.js",
        "content_scripts/airbnb_detector.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.expedia.com/*",
        "*://*.expedia.co.in/*"
      ],
      "js": [
        "parsers/base.js",
        "content_scripts/base_detector.js",
        "parsers/expedia.js",
        "content_scripts/expedia_detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Compare prices"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}